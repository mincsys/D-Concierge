{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "PDF文書検索に基づく回答。回答文のかたまりごとに根拠PDFページ範囲を紐づける。",
  "properties": {
    "answers": {
      "type": "array",
      "description": "回答文と根拠の組。最低1件。",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "description": "ユーザに提示する回答文のかたまり。"
          },
          "evidence": {
            "type": "array",
            "description": "この回答文の根拠。根拠がない場合は空配列。",
            "items": {
              "type": "object",
              "properties": {
                "pdf_path": {
                  "type": "string",
                  "description": "根拠となるPDFファイルのパス。可能ならワークスペースからの相対パス。"
                },
                "start_page": {
                  "type": "integer",
                  "description": "根拠範囲の開始PDFページ番号。1始まり。",
                  "minimum": 1
                },
                "end_page": {
                  "type": "integer",
                  "description": "根拠範囲の終了PDFページ番号。単一ページの場合はstart_pageと同じ値。",
                  "minimum": 1
                }
              },
              "required": ["pdf_path", "start_page", "end_page"],
              "additionalProperties": false
            }
          }
        },
        "required": ["text", "evidence"],
        "additionalProperties": false
      }
    }
  },
  "required": ["answers"],
  "additionalProperties": false
}
