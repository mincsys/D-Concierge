{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "description": "検証用Codex出力。中間メッセージはprogress、最終検証結果はfinalとしてpayload.kindで区別する。",
  "properties": {
    "payload": {
      "description": "Codexが出力する中間メッセージまたは最終検証結果。",
      "anyOf": [
        {
          "type": "object",
          "description": "利用者へ逐次表示する中間メッセージ。",
          "properties": {
            "kind": {
              "type": "string",
              "const": "progress",
              "description": "中間メッセージであることを示す識別子。"
            },
            "text": {
              "type": "string",
              "description": "利用者へ表示する中間メッセージ本文。"
            }
          },
          "required": ["kind", "text"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "description": "回答候補の参照元検証結果。",
          "properties": {
            "kind": {
              "type": "string",
              "const": "final",
              "description": "最終検証結果であることを示す識別子。"
            },
            "valid": {
              "type": "boolean",
              "description": "検証に合格した場合はtrue、不合格の場合はfalse。"
            },
            "comment": {
              "type": "string",
              "description": "validがtrueの場合は空文字。falseの場合は修正指示として利用できる詳細な指摘内容。"
            }
          },
          "required": ["kind", "valid", "comment"],
          "additionalProperties": false
        }
      ]
    }
  },
  "required": ["payload"],
  "additionalProperties": false
}
